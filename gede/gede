sub ProcessOption
  { # Usage:  &ProcessOption($optionstring);
    # Fetch and evaluate option(s)
  my($o) = @_;
  my(@o,$no);

  if ($o eq "--details") { $O{'details'}++; next; }
  if ($o eq "--help")    { &PrintUsage(); exit 0; }
  if ($o eq "--keinestatistik") { $O{'statistics'} = $false; next; }
  if ($o eq "--version") { &PrintScriptID(); exit 0; }
  if ($o =~ /^--/) { &Warn("Unbekannte Option '$o' im Aufrauf von $ScriptName, ignoriert"); return; }
  @o = split(//,$o);
  shift @o; # Remove leading -
  foreach $no (@o) { # Process single character options
    if ($no eq "d") { $O{'details'}++; next; }
    if ($no eq "h") { &PrintUsage(); exit 0; }
    if ($no eq "s") { $O{'statistics'} = $false; next; }
    if ($no eq "W") { $O{'warn'} = 0; next; }
    if ($no eq "V") { &PrintScriptID(); exit 0; }
    if ($no eq "?") { &PrintUsage(); exit 0; }
    &Warn("Unbekannte Option '$no' im Aufruf von $ScriptName, ignoriert");
    } # Process single letter options
  return;
  } # sub Processoption

