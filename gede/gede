sub KategorisiereDateiname
  { # Usage:  $Kategorie = &KategorisiereDateiname($Dateiname);
    # Analysiert den Dateinamen sowie die Eigenschaft der Datei und gibt den ermittelnden Wert als
    # Zeichenkette zurĆ¼ck.
    # Dateinamen werden syntaktisch und teils semantisch geprĆ¼ft.
  my($Dateiname) = @_;
  my($Basename,$Extension,$Message,$Nice);
  
  if ( $Dateiname eq "." ) { return "Systemverzeichnis"; }
  if ( $Dateiname eq ".." ) { return "Systemverzeichnis"; }
  if ( $Dateiname =~ /^ALT_/ ) { return "ALT"; }
  if ( $Dateiname =~ /\.bak$/i ) { return "bak"; }
  if ( $Dateiname =~ /\.log$/i ) { return "log"; }
  if ( $Dateiname =~ /ZZTemplate/i ) { return "Template"; }
  if ( $Dateiname =~ /^Kopie von/ ) { return "KopieVon"; }
  if ( $Dateiname =~ /^Copy of/ ) { return "KopieVon"; }
  if ( -d $Dateiname ) {
    if ( $Dateiname !~ /^[A-Za-z][_A-Za-z0-9-]*$/ ) {
      $Message = "UnerwĆ¼nschte Zeichen im Verzeichnisnamen Ā»$cf$Dateiname$crĀ«\n";
      $Nice = &nice_string($Dateiname);
      $Message .= "         Verzeichnisname escaped: Ā»$ce$Nice$crĀ«";
      &Warn($Message);
      }
    return "Verzeichnis";
    } # UnerwĆ¼nschte Zeichen Verzeichnisnamen
  if ( not (-f $Dateiname) ) { return "WederDateiNochVerzeichnis"; }
  if ( -z $Dateiname ) { return "leer"; }
  
  # Alle nicht-normale Dateien sind behandelt: Weiter kategorisieren.
  if ( $Dateiname =~ /^\./ ) { return "UnixHidden"; }
  if ( $Dateiname !~ /\./ ) { return "OhneExtension"; }
  if ( $Dateiname !~ /^(.*)\.([^.]+)$/ ) {
    $Message = "Dateiname Ā»$cf$Dateiname$crĀ« hat nicht die Form basename.extension.\n";
    $Nice = &nice_string($Dateiname);
    $Message .= "         Dateiname escaped: Ā» $ce$Nice$crĀ«";
    &Warn($Message);
    }
  $Basename = $1;
  $Extension = $2;
  push(@{$S{'Extensionen'}},$Extension);
  if ( $Basename !~ /^[A-Za-z][_A-Za-z0-9-]*$/ ) {
    $Message = "UnerwĆ¼nschte Zeichen im Dateinamen Ā»$cf$Dateiname$crĀ«\n";
    $Nice = &nice_string($Dateiname);
    $Message .= "         Dateiname escaped: Ā»$ce$Nice$crĀ«";
    &Warn($Message);
    return "unerwĆ¼nscht";
    }
                #&Dprint("Dateiname: '$Dateiname', Basename: '$Basename', Extension '$Extension'"); # exit 7;
  if ( $Extension =~ /^bak$/i ) { return "bak"; }
  if ( $Extension =~ /^log$/i ) { return "log"; }
  if ( $Extension =~ /^html$/i ) { return "html"; }
  if ( $Extension =~ /^docx$/i ) { return "docx"; }

  return "unkategorisiert";
  } # KategorisiereDateiname

sub ReadUTF8File
  { # Usage:   @Zeilen = &ReadUTF8File($Dateiname);
    # Liest den Inhalt der Datei $Dateiname und gibt diesen (ohne Newlines usw.) zurĆ¼ck
    # Falls etwas nicht funktioniert wie erwartet, werden entsprechende Meldungen ausgegeben.
  my($Dateiname) = @_;
  my($INUTF8);
  my(@Zeilen) = ();
  my($tt,$AbsDateiname);
  my($l) = 0;

  if ( not open($INUTF8,"<:utf8",$Dateiname) ) {
    $AbsDateiname = File::Spec->rel2abs($Dateiname,"");
    &Warn("Datei Ā»$cf$AbsDateiname$crĀ« konnte nicht zum Lesen geĆ¶ffnet werden");
    return @Zeilen;
    } # open failed

  while (<$INUTF8>) {
    chomp($_);
    $tt = $_;
    $l++;
    push(@Zeilen,$tt);
    } # while (<$INUTF8>)

  close($INUTF8);
  return @Zeilen;
  } # sub ReadUTF8File

