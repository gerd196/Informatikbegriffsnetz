sub LiesBegriffe
  { # Usage:  &LiesBegriffe($DirName);
    # Falls irgenndetwas schief geht, wird eine geeignete Fehlermeldung ausgegeben und die
    # Ausführung mit einem Fehlercode beendet.
  my($DirName) = @_;
  my($Message) = "$ScriptName: Internal error: Should never be printed";
  my($CurrentDir,$DirHandle,$Dateiname,$UpDir);
  my(@Dateinamen) = ();

  &CheckInputDir($DirName);

  if ( not chdir($DirName) ) {
    $Message = "Wechsel in das Verzeichnis $DirName nicht möglich.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   In $DirName sollten die Eingabedateien stehen und verarbeitet werden.";
      }
    &Error($Message);
    &Exit(1);
    }
  $CurrentDir = File::Spec->rel2abs(".","");
  if ( $O{'details'} > 3 ) { print(color("green"),"→→→ $CurrentDir",color("reset"),"\n"); }
  if ( not opendir($DirHandle,".") ) {
    $Message = "Basisverzeichnis $CurrentDir der Begriffe kann nicht geöffnet werden.";
    &Error($Message);
    &Exit(1),
    }
  @Dateinamen = readdir($DirHandle);
  if ( not closedir($DirHandle) ) {
    $Message = "Basisverzeichnis $CurrentDir der Begriffe kann nach dem Lesen der Dateinamen nicht geschlossen werden.";
    &Error($Message);
    &Exit(1),
    }
                #&DumpArray(\@Dateinamen,"\nDateinamen"); # exit 7;
  foreach $Dateiname (@Dateinamen) {
    &ProcessDateiname($CurrentDir,$Dateiname);
    } # foreach @Dateinamen

  $UpDir = File::Spec->updir();
  if ( not chdir($UpDir) ) {
    $Message = "Wechsel in das übergeordnete Verzeichnis von $CurrentDir aus nicht möglich.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   Im übergeordneten Verzeichnis sollten im Unterverzeichnis web2.0 die Ergebnisse erstellt werden.";
      }
    &Error($Message);
    &Exit(1);
    }
  $CurrentDir = File::Spec->rel2abs(".","");
  if ( $O{'details'} > 3 ) { print(color("magenta"),"←←← $CurrentDir",color("reset"),"\n"); }
  return;
  } # sub LiesBegriffe()
 
sub ProcessDateiname
  { # Usage:  &ProcessDateiname($CurrentDir,$Dateiname);
    # Startpunkt und Teil der rekursiven Verarbeitung der Dateihierarchie
  my($CurrentDir,$Dateiname) = @_;
  my($Kategorie);

  $Kategorie = &KategorisiereDateiname($Dateiname);
                #&Dprint("$Dateiname: $Kategorie"); # exit 7;

  if ( $Kategorie eq "Systemverzeichnis" ) {
    $S{'Systemverzeichnisse'} += 1;
    return;
    } # Systemverzeichnis

  if ( $Kategorie eq "ALT" ) {
    push(@{$S{'ALT'}},$Dateiname);
    return;
    } # ALT

  if ( $Kategorie eq "Template" ) {
    push(@{$S{'Template'}},$Dateiname);
    return;
    } # Template

  if ( $Kategorie eq "KopieVon" ) {
    push(@{$S{'KopieVon'}},$Dateiname);
    return;
    } # ALT

  if ( $Kategorie eq "WederDateiNochVerzeichnis" ) {
    push(@{$S{'WederDateiNochVerzeichnis'}},$Dateiname);
    return;
    } # WederDateiNochVerzeichnis

  if ( $Kategorie eq "Verzeichnis" ) {
    push(@{$S{'Verzeichnis'}},$Dateiname);
    &ProcessVerzeichnisname($Dateiname);
    return;
    } # Verzeichnis

  if ( $Kategorie eq "leer" ) {
    push(@{$S{'leer'}},$Dateiname);
    return;
    } # leer

  if ( $Kategorie eq "UnixHidden" ) {
    push(@{$S{'UnixHidden'}},$Dateiname);
    return;
    } # UnixHidden

  if ( $Kategorie eq "OhneExtension" ) {
    push(@{$S{'OhneExtension'}},$Dateiname);
    return;
    } # OhneExtension

  if ( $Kategorie eq "unerwünscht" ) {
    push(@{$S{'unerwünscht'}},$Dateiname);
    return;
    } # Template

  if ( $Kategorie eq "html" ) {
    push(@{$S{'html'}},$Dateiname);
    return;
    } # html

  if ( $Kategorie eq "docx" ) {
    push(@{$S{'docx'}},$Dateiname);
    &ProcessDocx($Dateiname);
    return;
    } # docx

  if ( $Kategorie eq "unkategorisiert" ) {
    push(@{$S{'unkategorisiert'}},$Dateiname);
    return;
    } # Template
                &Dprint("$Dateiname: $Kategorie"); # exit 7;
  return;
  } # sub ProcessDateiname

sub ProcessVerzeichnisname
  { # Usage:  &ProcessVerzeichnisname($DirName);
    # Liest die Dateinamen im Unterverzeichnis $DirName ein und ruft für jeden Dateinamen
    # &ProcessDateiname auf
    # Teil der rekursiven Verarbeitung der Dateihierarchie
  my($DirName) = @_;
  my($Message) = "$ScriptName: Internal error: Should never be printed";
  my($DirHandle,$CurrentDir,$Dateiname,$UpDir,$PerlErrorMessage);
  my(@Dateinamen) = ();

  if ( not chdir($DirName) ) {
    $PerlErrorMessage = $!;
    $Message = "Wechsel in das Unterverzeichnis $DirName nicht möglich.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   In $DirName sollten Eingabedateien stehen und verarbeitet werden.";
      if ( $O{'details'} > 2 ) {
        $Message .= "\n                       Perl-Error-Message: $PerlErrorMessage";
        } 
      }
    &Error($Message);
    &Exit(1);
    }
  $CurrentDir = File::Spec->rel2abs(".","");
  if ( $O{'details'} > 3 ) { print(color("green"),"→→→",color("reset")," $CurrentDir\n"); }
  if ( not opendir($DirHandle,".") ) {
    $Message = "Unterverzeichnis $CurrentDir kann nicht geöffnet werden.";
    &Error($Message);
    &Exit(1),
    }
  @Dateinamen = readdir($DirHandle);
  if ( not closedir($DirHandle) ) {
    $Message = "Unterverzeichnis $CurrentDir kann nach dem Lesen der Dateinamen nicht geschlossen werden.";
    &Error($Message);
    &Exit(1),
    }
                #&DumpArray(\@Dateinamen,"\nDateinamen");  exit 7;
  foreach $Dateiname (@Dateinamen) {
    &ProcessDateiname($CurrentDir,$Dateiname);
    } # foreach @Dateinamen

  $UpDir = File::Spec->updir();
  if ( not chdir($UpDir) ) {
    $Message = "Wechsel in das übergeordnete Verzeichnis von $CurrentDir nicht möglich.";
    &Error($Message);
    &Exit(1);
    }
  $CurrentDir = File::Spec->rel2abs(".","");
  if ( $O{'details'} > 3 ) { print(color("magenta"),"←←←",color("reset")," $CurrentDir\n"); }
  return;
  }  # sub ProcessVerzeichnisname

