sub WriteNewUTF8File
  { # Usage:  $Status = &WriteNewUTF8File($Filename,$z_text);
    # Writes content of $z_text to file $filename and closes $filename
    # Falls etwas nicht funktioniert wie erwartet, werden entsprechende Meldungen
    # ausgegeben und eventuell die AusfĆ¼hrung beendet.
    # Returns TRUE if file was successfully written, else FALSE
  my($Filename,$z_text) = @_;
  my($AbsFilename) = File::Spec->rel2abs($Filename,"");
  my($OUTUTF8);
  my($l,$line,$nextlinenumber,$Status,$PerlErrorMessage);
  my($Message) = "$ScriptName: Internal error in WriteNewUTF8File: Should never be printed";

  $l = scalar(@$z_text);

  if ( -e $Filename ) {
    $Status = rename($Filename,"$Filename.bak");
    $PerlErrorMessage = "$!";
    $Message = "$cr $AbsFilename $chāāā$cr $AbsFilename.bak";
    if ( $O{'details'} > 3 ) {
      if ( not $Status ) { $Message .= ": Perl-Fehler $PerlErrorMessage"; }
      print("    $Message\n");
      }
    } # Filename exists: Rename

  $Status = open($OUTUTF8,">:utf8",$Filename);
  if ( not $Status ) {
    $PerlErrorMessage = "$!";
    $Message = "Ā»$cf$AbsFilename$crĀ« kann nicht zum Schreiben geĆ¶ffnet werden. Perl-Fehler: $PerlErrorMessage";
    &Warn($Message);
    return FALSE;
    } # open failed

  $nextlinenumber = 1;
  foreach $line (@$z_text) {
    $Status = print($OUTUTF8 "$line\n");
    if ( not $Status ) {
      $PerlErrorMessage = "$!";
      $Message = "Fehler (Perl: $PerlErrorMessage) beim Schreiben von Zeile $nextlinenumber (von $l Zeilen) in Ā»$cf$AbsFilename$crĀ«.";
      close($OUTUTF8); # Sicherheitshalber probieren
      if ( $O{'details'} > 2 ) {
        $Message .= "\n      MaĆnahmen: 1. PrĆ¼fen, ob in das Verzeichnis geschrieben werden kann.";
        $Message .= "\n                 2. PrĆ¼fen, ob im Dateisystem noch Platz ist.";
        }
      &Warn($Message);
      return FALSE;
      } # Schreibfehler
      $nextlinenumber++;
    } # Schreibschleife

  $Status = close($OUTUTF8);
  if ( not $Status ) {
    $PerlErrorMessage = "$!";
    $Message = "Fehler (Perl: $PerlErrorMessage) beim SchlieĆen der Datei Ā»$cf$AbsFilename$crĀ«.";
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      MaĆnahmen: 1. PrĆ¼fen, ob die Datei richtig geschrieben wurde.";
      $Message .= "\n                 2. PrĆ¼fen, ob es sonstige Fehler im Dateisystem gibt.";
      }
    &Warn($Message);
    return FALSE;
    }

  $l = $nextlinenumber - 1;
  push(@{$S{'NewFilesWritten'}},"$AbsFilename ($l Zeilen)");
  return TRUE;
  } # WriteNewUTF8File

