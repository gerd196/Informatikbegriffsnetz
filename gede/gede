sub CheckArgs
  { # Usage:   &CheckArgs();
  my($parameter, $Text);
  my(@Arguments) = ();

  foreach $parameter (@ARGV)
    { # Check parameters
    if ($parameter =~ /^-/) { &ProcessOption($parameter); } # Option found
    else { &ErrorU("Option erwartet, $parameter gefunden."); }
    } # Check parameters

  return;
  } # sub CheckArgs

sub ProcessOption
  { # Usage:  &ProcessOption($optionstring);
    # Fetch and evaluate option(s)
  my($o) = @_;
  my(@o,$no);

  if ($o eq "--help")    { &PrintUsage(); exit 0; }
  if ($o eq "--version") { &PrintScriptID(); exit 0; }
  if ($o =~ /^--/) { return; } # Unknown long option: ignore
  @o = split(//,$o);
  shift @o; # Remove leading -
  $no = shift(@o); # Fetch option
  if ($no eq "d") { $O{'debug'}++; }
  if ($no eq "h") { &PrintUsage(); exit 0; }
  if ($no eq "W") { $O{'warn'} = 0; }
  if ($no eq "V") { &PrintScriptID(); exit 0; }
  if ($no eq "?") { &PrintUsage(); exit 0; }
  return;
  } # sub Processoption

sub CheckFile
  { # Usage:  $result = &CheckFile($filename);
    # Checks if the file with name as parameter is
    # a readable (and writeable) regular file.
  my($fname) = @_;

  if ( not -e $fname ) { return $false; }
  if ( not -f $fname ) { return $false; }
  if ( not -r $fname ) { return $false; }
  #if ( not -w $fname ) { return $false; }
  return $true;
  } # CheckFile

sub CheckFileExistence
  { # Usage:  $result = &CheckFileExistence($filename);
    # Checks if the file with name as parameter exists,
    # is a readable regular file of nonzero size.
  my($fname) = @_;

  if ( not -e $fname ) { # doesn't exist
    &ErrorU("Datei '$fname' nicht gefunden");
    return;
    } # doesn't exist
  if ( not -f $fname ) { # no plain file
    &ErrorU("Datei '$fname' ist eine spezielle Datei");
    return;
    } # no plain file
  if ( not -r $fname ) { # not readable
    &ErrorU("Datei '$fname' ist nicht lesbar");
    return;
    } # not readable
  if ( -z $fname ) { # zero size
    &ErrorU("Datei '$fname' ist leer");
    return;
    } # zero size

  return $true;
  } # CheckFileExistence

sub ReadUTF8File
  { # Usage:   &ReadUTF8File($filename,$z_array);
  my($fname,$z_array) = @_;
  my($tt);
  my($l) = 0;

  if (not open(INUTF8,"<:utf8",$fname)) {
    &Error("Datei '$fname' konnte nicht zum Lesen geöffnet werden");
    } # open failed

  while (<INUTF8>) {
    chomp($_);
    $tt = $_;
    $l++;
    push(@$z_array,$tt);
    } # while (<INTP>)

  close(INUTF8);
  return;
  } # sub ReadUTF8File

