sub ProcessDocx
  { # Usage:  &ProcessDocx($Dateiname);
    # Konvertiert durch einen Aufruf von Pandoc die .docx-Datei mit Namen $Dateiname im
    # aktuellen Arbeitsverzeichnis in ein HTML-Fragment, das mit dem absoluten Dateinamen
    # als Key in $HTMLbyFilename abgelegt wird, sofern dieses mindestens $O{'MinHTMLSize'}
    # Zeilen enthĆ¤lt.
    # Mit der -H-Option wird das konvertierte HTML im aktuellen Verzeichnis mit der Extension
    # .html # gespeichert.
    # Falls etwas nicht funktioniert wie erwartet, werden entsprechende Meldungen ausgegeben.
  my($Dateiname) = @_;
  my($AbsDateiname) = File::Spec->rel2abs($Dateiname,"");
  my($Basename) = "";
  my($HTMLname) = "";
  my($STDERRname) = "pandocFehler.log";
  my($PandocLogname) = "pandoc.log";
  my(@HTML) = ();
  my($PandocExitCode);
  my($PandocCall) = "pandoc --version 2>&1";
  my($Message) = "$ScriptName: Internal error ProcessDocx: Should never be printed";

  if ( $Dateiname !~ /^(.+)\.docx$/i ) {
    $Message = "ProcessDocx: Dateiname $cf$AbsDateiname$cr ist zu kurz bzw. hat keine .docx-Extension, Ć¼bergangen.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Dateiname formal falsch
  $Basename = $1;

  if ( not ($Basename =~ /^[A-Za-z][_A-Za-z0-9-]*$/) ) {
    $Message = "ProcessDocx: Dateiname $cf$AbsDateiname$cr enthĆ¤lt unerwĆ¼nschte Zeichen, Ć¼bergangen.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Dateiname mit unerwĆ¼nschten Zeichen

  if ( not (-e $Dateiname) ) {
    $Message = "ProcessDocx: Datei $cf$AbsDateiname$cr existiert nicht, Ć¼bergangen.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Datei existiert nicht

  if ( not (-f $Dateiname) ) {
    $Message = "ProcessDocx: Datei $cf$AbsDateiname$cr ist keine ānormaleā Datei, Ć¼bergangen.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Datei keine āflacheā Datei

  if ( -z $Dateiname ) {
    $Message = "ProcessDocx: Datei $cf$AbsDateiname$cr ist leer, Verarbeitung sinnlos.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Dateiname leer

  if ( not (-r $Dateiname) ) {
    $Message = "ProcessDocx: Datei $cf$AbsDateiname$cr ist nicht lesbar, Ć¼bergangen.";
    $Message .= &AddM1() . &AddE1();
    &Warn($Message);
    return;
    } # Datei nicht lesbar

  $HTMLname = $Basename . ".html";
  $PandocLogname = $Basename . ".log";
  $STDERRname = $Basename . "_STDERR.log";

  $PandocCall = "pandoc -f docx -t html5 --wrap=none --syntax-highlighting=none --log=$PandocLogname --fail-if-warnings=true --verbose --extract-media=$S{'PandocMediaDir'} $Dateiname 2>>$STDERRname";
  # ascii=false ?
  # Extension empty_paragraphs ?
  if ( $O{'details'} > 4 ) { print("Pandoc-Aufruf: Ā»$cc$PandocCall$crĀ«\n"); }

  @HTML = qx/$PandocCall/;
  $PandocExitCode = $? >> 8;
  &ProcessPandocExitCode($PandocExitCode,$PandocCall) if ( $PandocExitCode != 0 );
  &ProcessPandocSTDERR($AbsDateiname,$STDERRname,$PandocCall);
  &ProcessPandocLog($AbsDateiname,$PandocLogname,$PandocCall) if ( -e $PandocLogname );

  &ProcessPandocHTML($AbsDateiname,$HTMLname,\@HTML);
  return;
  } # sub ProcessDocx

sub ProcessPandocSTDERR
  { # Usage:  &ProcessPandocSTDERR($AbsDateiname,$STDERRFilename,$PandocCall);
    # Analysiert das STDERR-File 2>... des Pandoc-Aufrufs zur Datei $AbsDateiname
    # Wird nur aufgerufen, wenn bereits geprĆ¼ft wurde, ob die STDERR-Datei existiert
    # Falls irgenndetwas nicht so ist, wie es sein soll, wird eine geeignete Meldung ausgegeben 
    # und eventuell die AusfĆ¼hrung mit einem Fehlercode beendet.
  my($AbsDateiname,$Filename,$PandocCall) = @_;
  my($Message,$Meldung,$MediaFilename,$i,$Status);
  my(@PandocMeldungen) = ();
  my(@NichtbehandelteMeldungen) = ();

  if ( not (-f $Filename) ) {
    $Message = "Aufruf von Pandoc ($PandocCall) erzeugte eine Fehlerausgabedatei, die keine ānormaleā Datei ist.";
    $Message .= &AddP1($Filename) . &AddM1() . &AddE2;
    unlink($Filename) if ( $O{'DeleteLogfiles'} );
    &Error($Message); # &Exit(1);
    } # Fehlerausgabedatei keine āflacheā Datei
 
  if ( not (-r $Filename) ) {
    $Message = "Aufruf von Pandoc ($PandocCall) erzeugte eine nicht lesbare Fehlerausgabedatei.";
    $Message .= &AddP1($Filename) . &AddM1() . &AddE2;
    unlink($Filename) if ( $O{'DeleteLogfiles'} );
    &Error($Message); # &Exit(1);
    } # Fehlerausgabedatei nicht lesbar

  if ( -z $Filename ) {
    unlink($Filename);
    return;
    } # Fehlerausgabedatei leer

  @PandocMeldungen = &ReadUTF8File($Filename);
                #&DumpArray(\@PandocMeldungen,"\nPandocMeldungen");  #exit 7;
  unlink($Filename) if ( $O{'DeleteLogfiles'} ); # Gelesen ist gelesen ...
  return if ( scalar(@PandocMeldungen) < 1 ); # Ziemlich leer ...

  @NichtbehandelteMeldungen = ();
  foreach $Meldung (@PandocMeldungen) {
    next if ( $Meldung =~ /^\s*$/ ); # Ziemlich leere Meldung ...
    if ( $Meldung =~ /^\s*\[INFO] Extracting (.*)\.\.\.$/ ) {
      $MediaFilename = $1;
      $Status = &ProcessMediaExtraction($AbsDateiname,$MediaFilename,$Meldung);
                #&Dprint("MediaFilename Ā»$MediaFilenameĀ«"); # exit 7;
      next if ( $Status );
      } # Meldung zur Extraktion einer Media-Datei
    push(@NichtbehandelteMeldungen,$Meldung);
    }

  $i = scalar(@NichtbehandelteMeldungen);
  if ( $i > 0 ) {
    $Message = "$i nicht ausgewertete Meldungen des Pandoc-Aufrufs Ā»$cc$PandocCall$crĀ«:";
    foreach $Meldung (@NichtbehandelteMeldungen) { $Message .= "\n        Ā»$MeldungĀ«"; }
    &Warn($Message);
    }

  unlink($Filename) if ( $O{'DeleteLogfiles'} ); # Sicher ist sicher
  return;
  } # sub ProcessPandocSTDERR

sub ProcessMediaExtraction
  { # Usage:  $Status = &ProcessMediaExtraction($AbsDateiname,$MediaFilename,$Meldung);
    # Separiert aus $MediaFilename den Dateinamen der extrahierten Mediendatei und speichert die Extraktion in
    # %MedianameToFilename, nachdem dieser auf Eindeutigkeit untersucht wurde.
    # Sollte bereits eine Extraktion mit diesem Namen in $MedianameToFilename gespeichert sein,
    # wird eine Warnung generiert.
    # Falls irgenndetwas nicht so ist, wie es sein soll, wird eine geeignete Meldung ausgegeben 
    # und eventuell die AusfĆ¼hrung mit einem Fehlercode beendet.
  my($AbsDateiname,$Filename,$Meldung) = @_;
  my($Index,$l,$Rest,$ZielDateiname,$AlterDateiname);
  my($Message) = "$ScriptName: Internal error ProcessMediaExtraction: Should never be printed";

  $Index = index($Filename,$S{'PandocMediaDir'});
  if ( $Index != 0 ) {
    $Message = "Meldung zur Medienextraktion aus der Datei Ā»$cf$AbsDateiname$crĀ«: Unerwartetes Format:";
    $Message .= "\n                   Zieldateiname beginnt nicht mit Ā»$cf$S{'PandocMediaDir'}$crĀ«.";
    $Message .= "\n                   Meldung Ā»$co$Meldung$crĀ« nicht verarbeitet.";
    &Warn($Message);
    return FALSE;
    } # Pandoc Medien-Verzeichnis nicht Bestandteil des Media-Filenamens

  $l = length($S{'PandocMediaDir'});
  $Rest = substr($Filename,$l + 1);
  if ( $Rest !~ /^media.(.*$)/ ) {
    $Message = "Zieldateiname der Medienextraktion aus der Datei Ā»$cf$AbsDateiname$crĀ«: Unerwartetes Format:";
    $Message .= "\n                   Zieldateiname enthĆ¤lt nicht das Verzeichnis Ā»${cf}media$crĀ«.";
    $Message .= "\n                   Meldung Ā»$co$Meldung$crĀ« nicht verarbeitet.";
    &Warn($Message);
    return FALSE;
    } # Unerwartetes Rest-Format

  $ZielDateiname = $1;

  if ( exists($MedianameToFilename{$ZielDateiname}) ) {
    $AlterDateiname = $MedianameToFilename{$ZielDateiname};
    $Message = "ZielDateiname Ā»$cf$ZielDateiname$crĀ« der Medienextraktion aus der Datei Ā»$cf$AbsDateiname$crĀ«";
    $Message .= "\n                   hat die extrahierte Mediendatei aus der Datei Ā»$cf$AlterDateiname$crĀ« Ć¼berschrieben.";
    &Warn($Message);
    push(@{$S{'ĆberschriebeneMedien'}},"$ZielDateiname: $AlterDateiname ā $AbsDateiname");
    } # Doppelter Zieldateiname

  $MedianameToFilename{$ZielDateiname} = $AbsDateiname;
  return TRUE;
  } # sub ProcessMediaExtraction

