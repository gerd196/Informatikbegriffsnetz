    $Message = "Wechsel in das Verzeichnis Ā»$cf$DirName$crĀ« nicht mĆ¶glich.";
    if ( $O{'details'} > 0 ) { $Message .= $cr;
      $Message .= "\n                   In Ā»$cf$DirName$crĀ« (und Unterverzeichnissen) sollen die zu verarbeitenden Eingabedateien stehen.";
