sub ProcessOption
  { # Usage:  &ProcessOption($optionstring);
    # Fetch and evaluate option(s)
  my($o) = @_;
  my(@o,$no);

  if ($o eq "--details") { $O{'details'}++; return; }
  if ($o eq "--help")    { &PrintUsage(); exit 0; }
  if ($o eq "--HTML") { $O{'HTML'} = TRUE; return; }
  if ($o eq "--logs") { $O{'DeleteLogfiles'} = FALSE; return; }
  if ($o eq "--keinestatistik") { $O{'statistics'} = FALSE; return; }
  if ($o eq "--version") { &PrintScriptID(); exit 0; }
  if ($o =~ /^--/) { &Warn("Unbekannte Option Ā»$cw$o$crĀ« im Aufrauf von $ScriptName, ignoriert"); return; }
  @o = split(//,$o);
  shift @o; # Remove leading -
  foreach $no (@o) { # Process single character options
    if ($no eq "d") { $O{'details'}++; next; }
    if ($no eq "h") { &PrintUsage(); exit 0; }
    if ($no eq "H") { $O{'HTML'} = TRUE; next; }
    if ($no eq "l") { $O{'DeleteLogfiles'} = FALSE; next; }
    if ($no eq "s") { $O{'statistics'} = FALSE; next; }
    if ($no eq "t") { $O{'trace'} = TRUE; next; }
    if ($no eq "W") { $O{'warn'} = 0; next; }
    if ($no eq "V") { &PrintScriptID(); exit 0; }
    if ($no eq "?") { &PrintUsage(); exit 0; }
    &Warn("Unbekannte Option Ā»$cw$no$crĀ« im Aufruf von $ScriptName, ignoriert");
    } # Process single letter options
  return;
  } # sub Processoption

sub PruefePandocAufruf
  { # Usage:  &PruefePandocAufruf();
    # Wenn Pandoc installiert ist und aufgerufen werden kann, wird $S{'PandocVersion'} 
    # auf die installierte Version gesetzt.
    # Falls Pandoc nicht aufgerufen werden kann, werden Fehlermeldungen ausgegeben und das
    # Skript beendet.
  my(@Ergebnis,$PandocExitCode,$t,$Firstline,$PandocVersion,$PandocVersionsrest);
  my($Hauptversion,$Unterversion,$TestHauptversion,$TestUnterversion);
  my($Message) = "$ScriptName: Internal error PruefePandocAufruf: Should never be printed";
  my($PandocCall) = "pandoc --version 2>&1";

  @Ergebnis = qx/$PandocCall/;
  $PandocExitCode = $?;
                #&Dprint("Ergebnis: $Ergebnis, PerlErrorMessage: $PerlErrorMessage"); # exit 7;
                #&DumpArray(\@Ergebnis,"\nErgebnis");  #exit 7;
                #&Dprint("PerlErrorMessage: $PerlErrorMessage"); # exit 7;
  &ProcessPandocExitCode($PandocExitCode,$PandocCall) if ( $PandocExitCode != 0 );

  if ( scalar(@Ergebnis) < 1 ) {
    $Message = "Aufruf von Pandoc ($cc$PandocCall$cr) lieferte keine Ausgaben zurĆ¼ck.";
    if ( $O{'details'} > 0 ) { $Message .= $cr;
      $Message .= "\n                   Pandoc ab Version $O{'PandocTestversion'} soll zur Umwandlung von .docx in HTML-Form verwendet werden.";
      if ( $O{'details'} > 1 ) {
        $Message .= "\n                   Pandoc konnte mit dem Kommando Ā»$cc$PandocCall$crĀ« aufgerufen werden, hat aber keine Ausgaben zurĆ¼ckgeliefertr.";
        $Message .= "\n                   MaĆnahmen: In Kommandozeile (Eingabeaufforderung, Konsole, Terminal prĆ¼fen,";
        $Message .= "\n                   ob der Aufruf Ā»$cc$PandocCall$crĀ« zumindest eine Zeile Ausgaben erzeugt und in der";
        $Message .= "\n                   ersten Zeile die Version ausgibt.";
        } 
      }
    &Error($Message); # &Exit(1);
    } # pandoc --version: Ohne Ausgaben

  chomp(@Ergebnis);
  if ( $O{'details'} > 4 ) {
    print("Ausgabe(n) von Ā»$cc$PandocCall$crĀ«:\n");
    foreach $t (@Ergebnis) {
      print("    $t\n");
      }
    }
  $Firstline = $Ergebnis[0];
                #&Dprint("Firstline: $Firstline"); # exit 7;
  if ( $Firstline !~ /pandoc +([0-9]+\.[0-9]+)(.*)/i ) {
    $Message = "Erste Zeile der Ausgabe des Pandoc-Aufrufs ($cc$PandocCall$cr) hat nicht das Format einer Versionsangabe.";
    if ( $O{'details'} > 0 ) { $Message .= $cr;
      $Message .= "\n                   Wahrscheinlich verĆ¤ndertes Verhalten von Pandoc. Skript $ScriptName sollte angepasst werden.";
      $S{'PandocVersion'} = "nicht ermittelbar";
      &Warn($Message);
      return;
      }
    } # Keine Pandoc-Versionsangabe
  $PandocVersion = $1;
  $PandocVersionsrest = $2;

  $S{'PandocVersion'} = $PandocVersion . $PandocVersionsrest;
  if ( $PandocVersion !~ /([0-9]+)\.([0-9]+)/ ) {
    $Message = "$ScriptName: Internal error PruefePandocAufruf: Zweiter Test der Pandoc-Version gescheitert.";
    &Error($Message); # &Exit(1);
    }
  $Hauptversion = $1;
  $Unterversion = $2;
  if ( $O{'PandocTestversion'} !~ /([0-9]+)\.([0-9]+)/ ) {
    $Message = "$ScriptName: Internal error PruefePandocAufruf: O{'PandocTestversion'} falsch formatiert.";
    &Error($Message); # &Exit(1);
    }
  $TestHauptversion = $1;
  $TestUnterversion = $2;
    $Message = "Aufgerufene Pandoc-Version ($S{'PandocVersion'}) ist Ć¤lter als die, mit der $ScriptName entwickelt und getestet wurde ($O{'PandocTestversion'})";
    if ( $Hauptversion < $TestHauptversion ) {
      &Warn($Message);
      }
    if ( ($Hauptversion == $TestHauptversion) and ($Unterversion < $TestUnterversion) ) {
      &Warn($Message);
      }

  if ( $O{'details'} > 3 ) { print("Verwemdete ${co}Pandoc-Version:$cr $S{'PandocVersion'}\n"); }
  return;
  } #sub PruefePandocAufruf

