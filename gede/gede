sub ProcessDateiname
  { # Usage:  &ProcessDateiname($Dateiname);
    # Startpunkt und Teil der rekursiven Verarbeitung des Dateibaums
  my($Dateiname) = @_;
  my($Kategorie);

  $Kategorie = &KategorisiereDateiname($Dateiname);
                #&Dprint("$Dateiname: $Kategorie"); # exit 7;
  if ( $Kategorie eq "Systemverzeichnis" ) { $S{'Systemverzeichnisse'} += 1; return; }
  if ( $Kategorie eq "ALT" ) { push(@{$S{'ALT'}},$Dateiname); return; }
  if ( $Kategorie eq "Template" ) { push(@{$S{'Template'}},$Dateiname); return; }
  if ( $Kategorie eq "KopieVon" ) { push(@{$S{'KopieVon'}},$Dateiname); return; }
  if ( $Kategorie eq "WederDateiNochVerzeichnis" ) { push(@{$S{'WederDateiNochVerzeichnis'}},$Dateiname); return; }
  if ( $Kategorie eq "Verzeichnis" )
    { push(@{$S{'Verzeichnis'}},$Dateiname); &ProcessVerzeichnisname($Dateiname); return; }
  if ( $Kategorie eq "leer" ) { push(@{$S{'leer'}},$Dateiname); return; }
  if ( $Kategorie eq "UnixHidden" ) { push(@{$S{'UnixHidden'}},$Dateiname); return; }
  if ( $Kategorie eq "OhneExtension" ) { push(@{$S{'OhneExtension'}},$Dateiname); return; }
  if ( $Kategorie eq "unerwĆ¼nscht" ) { push(@{$S{'unerwĆ¼nscht'}},$Dateiname); return; }
  if ( $Kategorie eq "bak" ) { push(@{$S{'bak'}},$Dateiname); return; }
  if ( $Kategorie eq "log" ) { push(@{$S{'log'}},$Dateiname); return; }
  if ( $Kategorie eq "html" ) { push(@{$S{'html'}},$Dateiname); return; }
  if ( $Kategorie eq "docx" ) {
    push(@{$S{'docx'}},$Dateiname);
    &ProcessDocx($Dateiname);
                #&DumpHash(\%HTMLbyFilename,"\nHTMLbyFilename"); # exit 7;
    return;
    } # docx
  if ( $Kategorie eq "unkategorisiert" ) { push(@{$S{'unkategorisiert'}},$Dateiname); return; }
                &Dprint("$Dateiname: $Kategorie"); # exit 7;
  return;
  } # sub ProcessDateiname

