sub ProcessPandocExitCode
  { # Usage:  &ProcessPandocExitCode($PandocExitCode,$PandocCall);
    # Wandelt den numerischen Exit-Code des Pandoc in Text um, gibt diesen aus und stopt, falls != 0
  my($ExitCode,$Call) = @_;
  my($PM) = "$ExitCode";
  my($M);

  if    ( $ExitCode ==  1 ) { $PM .= " PandocIOError"; }
  elsif ( $ExitCode ==  3 ) { $PM .= " PandocFailOnWarningError"; }
  elsif ( $ExitCode ==  4 ) { $PM .= " PandocAppError"; }
  elsif ( $ExitCode ==  5 ) { $PM .= " PandocTemplateError"; }
  elsif ( $ExitCode ==  6 ) { $PM .= " PandocOptionError"; }
  elsif ( $ExitCode == 21 ) { $PM .= " PandocUnknownReaderError"; }
  elsif ( $ExitCode == 22 ) { $PM .= " PandocUnknownWriterError"; }
  elsif ( $ExitCode == 23 ) { $PM .= " PandocUnsupportedExtensionError"; }
  elsif ( $ExitCode == 24 ) { $PM .= " PandocCiteprocError"; }
  elsif ( $ExitCode == 25 ) { $PM .= " PandocBibliographyError"; }
  elsif ( $ExitCode == 31 ) { $PM .= " PandocEpubSubdirectoryError"; }
  elsif ( $ExitCode == 43 ) { $PM .= " PandocPDFError"; }
  elsif ( $ExitCode == 44 ) { $PM .= " PandocXMLError"; }
  elsif ( $ExitCode == 47 ) { $PM .= " PandocPDFProgramNotFoundError"; }
  elsif ( $ExitCode == 61 ) { $PM .= " PandocHttpError"; }
  elsif ( $ExitCode == 62 ) { $PM .= " PandocShouldNeverHappenError"; }
  elsif ( $ExitCode == 63 ) { $PM .= " PandocSomeError"; }
  elsif ( $ExitCode == 64 ) { $PM .= " PandocParseError"; }
  elsif ( $ExitCode == 66 ) { $PM .= " PandocMakePDFError"; }
  elsif ( $ExitCode == 67 ) { $PM .= " PandocSyntaxMapError"; }
  elsif ( $ExitCode == 83 ) { $PM .= " PandocFilterError"; }
  elsif ( $ExitCode == 84 ) { $PM .= " PandocLuaError"; }
  elsif ( $ExitCode == 89 ) { $PM .= " PandocNoScriptingEngine"; }
  elsif ( $ExitCode == 91 ) { $PM .= " PandocMacroLoop"; }
  elsif ( $ExitCode == 92 ) { $PM .= " PandocUTF8DecodingError"; }
  elsif ( $ExitCode == 93 ) { $PM .= " PandocIpynbDecodingError"; }
  elsif ( $ExitCode == 94 ) { $PM .= " PandocUnsupportedCharsetError"; }
  elsif ( $ExitCode == 95 ) { $PM .= " PandocInputNotTextError"; }
  elsif ( $ExitCode == 97 ) { $PM .= " PandocCouldNotFindDataFileError"; }
  elsif ( $ExitCode == 98 ) { $PM .= " PandocCouldNotFindMetadataFileError"; }
  elsif ( $ExitCode == 99 ) { $PM .= " PandocResourceNotFound"; }

  $M = "Aufruf von Pandoc ($cc$Call$cr) mit Fehler $PM gescheitert.";
  if ( $O{'details'} > 0 ) {
    $M .= "$cr\n                   Pandoc soll zur Umwandlung von .docx in HTML verwendet werden.";
    }
  if ( $O{'details'} > 1 ) {
    $M .= "\n        MaĆnahmen: In Kommandozeile (Eingabeaufforderung, Konsole, Terminal) prĆ¼fen,, ob der";
    $M .= "\n                   Aufruf Ā»$cc$Call$crĀ« gelingt und Ergebnisse liefert.";
    $M .= "\n                   Falls der Aufruf eine Fehlermeldung ausgibt, prĆ¼fen ob pandoc installiert ist.";
    $M .= "\n                   Falls nicht: pandoc installieren, z. B. von https://pandoc.org/installing.html";
    $M .= "\n                   Danach mindestens aus- und wieder einloggen (besser rebooten) und prĆ¼fen, ob";
    $M .= "\n                   der Aufruf Ā»${cc}pandoc --version$crĀ« gelingt und zumindest eine Zeile ausgibt.";
    $M .= "\n                   Falls nicht: PrĆ¼fen, ob das Installationsverzeichnis von pandoc im";
