sub DumpHash
  { # Usage:   &DumpHash($z_hash,$title);
  my($z_hash,$title) = @_;
  my($i,$j,$n,$m,$tt);
  my(@text) = ();

  print(color($O{"DumpColor"}));
  print("$title\n") if ( defined($title) );

  $n = scalar(keys(%$z_hash));
  $m = $n;
  $m = $O{'DumpLimit'} if ( $O{'DumpLimit'} < $m ); 
  $m--;
  $j = 0;
  foreach $i (sort(keys(%$z_hash))) {
    next if ($j > $m);
    $j++;
    $tt = $z_hash->{$i};
#    $tt = $$tt if (ref($tt));
    $tt = &nice_string($tt);
    push(@text,"$i -> $tt");
    }
  if ( $O{'DumpFilename'} ne "" ) {
    &WriteNewUTF8File($O{'DumpFilename'},\@text);
    print(" $n lines written to $O{'DumpFilename'}\n");
    } else {
    foreach $i (@text) { print("$i\n"); }
    print("  $n hash elements");
    }
  print(color("reset"),"\n");
  return ;
  } # sub DumpHash

sub DumpHashArray
  { # Usage:   &DumpHashArray($z_text,$title);
  my($z_hash,$title) = @_;
  my($i,$j,$n,$m,$tt,$z_tt);
  my(@text) = ();

  print(color($O{"DumpColor"}));
  print("$title\n") if ( defined($title) );

  $n = scalar(keys(%$z_hash));
  $m = $n;
  $m = $O{'DumpLimit'} if ( $O{'DumpLimit'} < $m ); 
