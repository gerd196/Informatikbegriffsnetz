sub CheckBaseDir
  { # Usage:  &CheckBaseDir();
    # Prüft ob das Basisverzeichnis $S{'BaseDir'} die erforderlichen Berechtigungen hat
    # Falls irgenndetwas nicht so ist, wie es sein soll, wird eine geeignete Fehlermeldung ausgegeben und die
    # Ausführung mit einem Fehlercode beendet.
  my($DirName) = $S{'BaseDir'};
  my($Message) = "$ScriptName: Internal error: Should never be printed";

  if ( not -e $DirName ) { # Seltsam: Aufrufverzeichnis soll nicht existieren
    $Message = "Aufrufverzeichnis $DirName existiert gemäß Betriebssystemabfrage nicht.";
    if ( $O{'details'} > 1 ) {
      $Message .= color('reset');
      $Message .= "\n         Maßnahme: Analysieren, was im Skript falsch läuft.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Dieser Fehler sollte nie vorkommen.";
      $Message .= "\n                   Falls doch, ist etwas Grundlegendes schief gegangen.";
      }
    &Error($Message);
    &Exit(1);
    } #  Seltsam: Aufrufverzeichnis soll nicht existieren

  if ( not -d $DirName ) { # Seltsam: Aufrufverzeichnis soll kein Verzeichnis sein
    $Message = "Aufrufverzeichnis $DirName ist gemäß Betriebssystemabfrage kein Verzeichnis.";
    if ( $O{'details'} > 1 ) {
      $Message .= color('reset');
      $Message .= "\n         Maßnahme: Analysieren, was im Skript falsch läuft.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Dieser Fehler sollte nie vorkommen.";
      $Message .= "\n                   Falls doch, ist etwas Grundlegendes schief gegangen.";
      }
    &Error($Message);
    &Exit(1);
    } #  Seltsam: Aufrufverzeichnis soll kein Verzeichnis sein

  if ( not -r $DirName ) { # Seltsam: Aufrufverzeichnis soll nicht lesbar sein
    $Message = "Aufrufverzeichnis $DirName ist gemäß Betriebssystemabfrage nicht lesbar.";
    if ( $O{'details'} > 1 ) {
      $Message .= color('reset');
      $Message .= "\n         Maßnahme: Analysieren, was im Skript falsch läuft.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Dieser Fehler sollte nie vorkommen.";
      $Message .= "\n                   Falls doch, ist etwas Grundlegendes schief gegangen.";
      }
    &Error($Message);
    &Exit(1);
    } #  Seltsam: Aufrufverzeichnis soll nicht lesbar sein

  if ( not -w $DirName ) { # Aufrufverzeichnis nicht beschreibbar
    $Message = "Aufrufverzeichnis $DirName nicht beschreibbar.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   In $DirName müssen Hilfs- und Ergebnisdateien geschrieben werden können.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n         Maßnahme: Schreibrechte für $DirName erteilen.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Für die Erstellung der HTML-Dateien müssen die von Google Docs erstellten";
      $Message .= "\n                   .docx-Dateien im Verzeichnis $DirName mit Pandoc in ein einfach";
      $Message .= "\n                   verarbeitbares Format umgewandelt und gespeichert werden und es werden die";
      $Message .= "\n                   erzeugten HTML-Dateien usw. in das Unterverzeichnis $O{'OutputDir'} geschrieben.";
      $Message .= "\n                   Dazu muss in das Verzeichnis $DirName geschrieben werden können.";
      }
    &Error($Message);
    &Exit(1);
    } #  Aufrufverzeichnis nicht beschreibbar

  if ( not -x $DirName ) { # Aufrufverzeichnis nicht durchsuchbar
    $Message = "Dateinamen im Aufrufverzeichnis $DirName nicht ermittelbar.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   Die Dateinamen in $DirName müssen ermittelbar sine, damit diese";
      $Message .= "\n                   verarbeitet werden können.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n         Maßnahme: Suchrechte (Unix usw: x) für $DirName erteilen.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Für die Erstellung der HTML-Dateien müssen die von Google Docs erstellten";
      $Message .= "\n                   .docx-Dateien im Aufrufverzeichnis $DirName mit Pandoc in ein einfach";
      $Message .= "\n                   verarbeitbares Format umgewandelt und gespeichert werden und es müssen";
      $Message .= "\n                   die Ergebnisse in das Unterverzeichnis $O{'OutputDir'} gespeichert werden.";
      $Message .= "\n                   Dazu sollte der Inhalt des von $DirName ermittelt werden können.";
      }
    &Error($Message);
    &Exit(1);
    } #  Aufrufverzeichnis nicht durchsuchbar

  return;
  } # CheckBaseDir

sub CheckInputDir
  { # Usage:  &CheckInputDir($DirName);
    # Prüft, ob $DirName ein les-, schreib und scanbares Verzeichnis im aktuellen Arbeitsverzeichnis ist.
    # Falls irgenndetwas nicht so ist, wie es sein soll, wird eine geeignete Fehlermeldung ausgegeben und die
    # Ausführung mit einem Fehlercode beendet.
  my($DirName) = @_;
  my($CurrentDir) = File::Spec->rel2abs(".","");
  my($Message) = "Internal error: Should never be printed";
                #&Dprint("\nCurrentDir: ",$CurrentDir); # exit 7;

  if ( not -e $DirName ) { # Verzeichnisname im aktuellen Verzeichnis nicht gefunden
    $Message = "Verzeichnis $DirName in $CurrentDir nicht gefunden.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   $DirName soll aus Google Docs heruntergeladene Begriffe enthalten.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n    Herunterladen: In Google Docs: Rechtsklick auf Verzeichnisnamen $DirName, die";
      $Message .= "\n                   errstellte .zip-Datei im Verzeichnis $S{'BaseDir'} speichern und mit einem";
      $Message .= "\n                   zip-Programm auspacken.";
      $Message .= "\n                   Danach prüfen, ob das Verzeichnis $DirName in $S{'BaseDir'} erstellt wurde und die";
      $Message .= "\n                   Begriffe aus Google Docs als .docx-Dateien enthält, auch in";
      $Message .= "\n                   Unterverzeichnissen.";
      }
    &Error($Message);
    &Exit(1);
    } #  Verzeichnisnamen im aktuellen Verzeichnis nicht gefunden

  if ( not -d $DirName ) { # Dateinamen vorhanden, ist aber unerwarteterweise kein Verzeichnis
    $Message = "Dateiname $DirName ist in $CurrentDir vorhanden, aber kein Verzeichnis.";
    if ( $CurrentDir eq $S{'BaseDir'} ) { # In BaseDir 
      if ( $O{'details'} > 0 ) {
        $Message .= color('reset');
        $Message .= "\n                   $DirName soll ein Verzeichnis sein, das aus Google Docs";
        $Message .= "\n                   heruntergeladene Begriffe enthält.";
        }
      if ( $O{'details'} > 1 ) {
        $Message .= "\n    Maßnahmen:     $DirName umbennen, Begriffe aus Google Docs herunterladen und auspacken.";
        }
      if ( $O{'details'} > 2 ) {
        $Message .= "\n    Herunterladen: In Google Docs: Rechtsklick auf Verzeichnisnamen $DirName, die";
        $Message .= "\n                   erstellte .zip-Datei im Verzeichnis $S{'BaseDir'} speichern und mit einem";
        $Message .= "\n                   zip-Programm auspacken.";
        $Message .= "\n                   Danach prüfen, ob das Verzeichnis $DirName erstellt wurde und die";
        $Message .= "\n                   Begriffe aus Google Docs als .docx-Dateien enthält, eventuell auch in";
        $Message .= "\n                   Unterverzeichnissen.";
        }
      } # In BaseDir
    else { # In Unterverzeichnis
      if ( $O{'details'} > 1 ) {
        $Message .= "\n    Maßnahmen:     Prüfen, ob der Download der Google Docs-Dateien sich anders verhält.";
        $Message .= "\n                   Verzeichnis $O{'InputDir'} in $S{'BaseDir'} löschen und von Google Docs";
        $Message .= "\n                   neu herunterladen.";
        $Message .= "\n                   Falls das nicht hilft, ist eine detaillierte Fehleranalyse erforderlich.";
        }
      if ( $O{'details'} > 2 ) {
        $Message .= "\n    Herunterladen: In Google Docs: Rechtsklick auf Verzeichnisnamen $DirName, die";
        $Message .= "\n                   erstellte .zip-Datei im Verzeichnis $S{'BaseDir'} speichern und mit einem";
        $Message .= "\n                   zip-Programm auspacken.";
        $Message .= "\n                   Danach prüfen, ob das Verzeichnis $DirName erstellt wurde und die";
        $Message .= "\n                   Begriffe aus Google Docs als .docx-Dateien enthält, auch in";
        $Message .= "\n                   Unterverzeichnissen.";
        }
      } # In Unterverzeichnis
    &Error($Message);
    &Exit(1);
    } #  Dateinamen vorhanden, ist aber unerwarteterweise kein Verzeichnis

  if ( not -r $DirName ) { # Eingabeverzeichnisnamen gefunden: nicht lesbar
    $Message = "Dateiname $DirName in $CurrentDir nicht lesbar.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   $DirName sollte ein lesbares Verzeichnis in $CurrentDir sein, das aus";
      $Message .= "\n                   Google Docs heruntergeladene Begriffe enthält.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n         Maßnahme: Leserechte für $DirName erteilen.";
      }
    &Error($Message);
    &Exit(1);
    } #  Eingabeverzeichnisnamen gefunden: nicht lesbar

  if ( not -w $DirName ) { # Eingabeverzeichnisnamen gefunden: nicht beschreibbar
    $Message = "Dateiname $DirName in $CurrentDir' nicht beschreibbar.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   In $DirName müssen Hilfsdateien geschrieben werden können.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n         Maßnahme: Schreibrechte für $DirName erteilen.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Für die Erstellung der HTML-Dateien müssen die von Google Docs erstellten";
      $Message .= "\n                   .docx-Dateien im Verzeichnis $DirName mit Pandoc in ein einfach";
      $Message .= "\n                   verarbeitbares Format umgewandelt und gespeichert werden.";
      $Message .= "\n                   Dazu muss in das Verzeichnis $DirName geschrieben werden können.";
      }
    &Error($Message);
    &Exit(1);
    } #  Eingabeverzeichnisnamen gefunden: nicht beschreibbar

  if ( not -x $DirName ) { # Eingabeverzeichnisnamen gefunden: nicht scanbar
    $Message = "Dateinamen im Verzeichnis $DirName in $CurrentDir' nicht ermittelbar.";
    if ( $O{'details'} > 0 ) {
      $Message .= color('reset');
      $Message .= "\n                   Die Dateinamen in $DirName müssen ermittelbar sein, damit diese";
      $Message .= "\n                   verarbeitet werden können.";
      }
    if ( $O{'details'} > 1 ) {
      $Message .= "\n         Maßnahme: Suchrechte (Unix usw: x) für $DirName erteilen.";
      }
    if ( $O{'details'} > 2 ) {
      $Message .= "\n      Erläuterung: Für die Erstellung der HTML-Dateien müssen die von Google Docs erstellten";
      $Message .= "\n                   .docx-Dateien im Verzeichnis $DirName mit Pandoc in ein einfach";
      $Message .= "\n                   verarbeitbares Format umgewandelt und gespeichert werden.";
      $Message .= "\n                   Dazu sollte der Inhalt des Verzeichnisses $DirName ermittelt werden können.";
      }
    &Error($Message);
    &Exit(1);
    } #  Eingabeverzeichnisnamen gefunden: nicht scanbar

  return;
  } # CheckInputDir

sub KategorisiereDateiname
  { # Usage:  $Kategorie = &KategorisiereDateiname($Dateiname);
    # Analysiert den Dateinamen sowie die Eigenschaft der Datei und gibt den ermittelnden Wert als
    # Zeichenkette zurück.
    # Dateinamen werden syntaktisch und eingeschränkt semantisch geprüft.
  my($Dateiname) = @_;
  my($Basename,$Extension,$Message,$Nice);
  
  if ( $Dateiname eq "." ) { return "Systemverzeichnis"; }
  if ( $Dateiname eq ".." ) { return "Systemverzeichnis"; }
  if ( $Dateiname =~ /^ALT_/ ) { return "ALT"; }
  if ( $Dateiname =~ /ZZTemplate/i ) { return "Template"; }
  if ( $Dateiname =~ /^Kopie von/ ) { return "KopieVon"; }
  if ( $Dateiname =~ /^Copy of/ ) { return "KopieVon"; }
  if ( -d $Dateiname ) {
    if ( $Dateiname !~ /^[A-Za-z][_A-Za-z0-9-]*$/ ) {
      $Message = "Unerwünschte Zeichen im Verzeichnisnamen " . color("blue") . "$Dateiname" . color("reset") . "\n";
      $Nice = &nice_string($Dateiname);
      $Message .= "         Verzeichnisname escaped: »" . color("cyan") . $Nice . color("reset") . "«";
      &Warn($Message);
      }
    return "Verzeichnis";
    }
  if ( not -f $Dateiname ) { return "WederDateiNochVerzeichnis"; }
  if ( -z $Dateiname ) { return "leer"; }
  
  # Alle nicht-normale Dateien sind behandelt: Weiter kategorisieren.
  if ( $Dateiname =~ /^\./ ) { return "UnixHidden"; }
  if ( $Dateiname !~ /\./ ) { return "OhneExtension"; }
  if ( $Dateiname !~ /^(.*)\.([^.]+)$/ ) {
    $Message = "Dateiname " . color("blue") . "$Dateiname" . color("reset") . "hat nicht die Form basename.extension.\n";
    $Nice = &nice_string($Dateiname);
    $Message .= "         Dateiname escaped: »" . color("cyan") . $Nice . color("reset") . "«";
    &Warn($Message);
    }
  $Basename = $1;
  $Extension = $2;
  push(@{$S{'Extensionen'}},$Extension);
  if ( $Basename !~ /^[A-Za-z][_A-Za-z0-9-]*$/ ) {
    $Message = "Unerwünschte Zeichen im Dateinamen " . color("blue") . "$Dateiname" . color("reset") . "\n";
    $Nice = &nice_string($Dateiname);
    $Message .= "         Dateiname escaped: »" . color("cyan") . $Nice . color("reset") . "«";
    &Warn($Message);
    return "unerwünscht";
    }
                #&Dprint("Dateiname: '$Dateiname', Basename: '$Basename', Extension '$Extension'"); # exit 7;
  if ( $Extension =~ /^html$/i ) { return "html"; }
  if ( $Extension =~ /^docx$/i ) { return "docx"; }

  return "unkategorisiert";
  } # KategorisiereDateiname

sub CheckFileReadability
  { # Usage:  $result = &CheckFileReadability($filename);
    # Checks if the file with name as parameter exists,
    # is a readable regular file of nonzero size.
  my($fname) = @_;

  if ( not -e $fname ) { # doesn't exist
    &ErrorU("Datei '$fname' nicht gefunden");
    return;
    } # doesn't exist
  if ( not -f $fname ) { # no plain file
    &ErrorU("Datei '$fname' ist eine spezielle Datei");
    return;
    } # no plain file
  if ( not -r $fname ) { # not readable
    &ErrorU("Datei '$fname' ist nicht lesbar");
    return;
    } # not readable
  if ( -z $fname ) { # zero size
    &ErrorU("Datei '$fname' ist leer");
    return;
    } # zero size

  return $true;
  } # CheckFileReadability

sub ReadUTF8File
  { # Usage:   &ReadUTF8File($filename,$z_array);
  my($fname,$z_array) = @_;
  my($tt);
  my($l) = 0;

  if (not open(INUTF8,"<:utf8",$fname)) {
    &Error("Datei '$fname' konnte nicht zum Lesen geöffnet werden");
    } # open failed

  while (<INUTF8>) {
    chomp($_);
    $tt = $_;
    $l++;
    push(@$z_array,$tt);
    } # while (<INTP>)

  close(INUTF8);
  return;
  } # sub ReadUTF8File

