sub nice_string {
  join("",
    map { $_ > 126 ?
      sprintf("\\x{%04X}", $_) :
      chr($_) =~ /[[:cntrl:]]/ ?
      sprintf("\\x%02X", $_) :
      chr($_)
    } unpack("U*", $_[0]));
  } # sub nice_string
