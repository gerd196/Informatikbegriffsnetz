sub CurrentTime
  { # Usage:  &CurrentTime();
  my($now,$tt);
  my($sec,$min,$hour,$mday,$mon,$year,$wday,$yday,$isdst) = localtime();

  $year += 1900;
  $now = "$year";
  $mon += 1; $tt = "$mon"; $tt = "0$tt" if ($mon < 10);
  $now .= "-" . $tt;
  $tt = "$mday"; $tt = "0$tt" if ($mday < 10);
  $now .= "-" . $tt;
  $tt = "$hour"; $tt = "0$tt" if ($hour < 10);
  $now .= " " . $tt;
  $tt = "$min"; $tt = "0$tt" if ($min < 10);
  $now .= ":" . $tt;
  $tt = "$sec"; $tt = "0$tt" if ($sec < 10);
  $now .= ":" . $tt;

  return $now;
  } # sub CurrentTime
 
