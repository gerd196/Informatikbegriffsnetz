sub CheckFileReadability
  { # Usage:  $result = &CheckFileReadability($filename);
    # Checks if the file with name as parameter exists,
    # is a readable regular file of nonzero size.
  my($fname) = @_;

  if ( not (-e $fname) ) { # doesn't exist
    &ErrorU("Datei '$fname' nicht gefunden");
    return;
    } # doesn't exist
  if ( not (-f $fname) ) { # no plain file
    &ErrorU("Datei '$fname' ist eine spezielle Datei");
    return;
    } # no plain file
  if ( not (-r $fname) ) { # not readable
    &ErrorU("Datei '$fname' ist nicht lesbar");
    return;
    } # not readable
  if ( -z $fname ) { # zero size
    &ErrorU("Datei '$fname' ist leer");
    return;
    } # zero size

  return TRUE;
  } # CheckFileReadability

sub CheckOutFile
  { # Usage: $result = &CheckoutFile($filename);
    # Checks if the file with name as parameter is writeable.
    # Returns empty string if yes and Error-Message if not
  my($fname) = @_;
  my($Message) = "Internal error CheckOutFile: Should never be printed";

  if ( -e $fname ) {
    if ( -d $fname ) {
      $Message = "'$fname' ist ein Verzeichnisnamen, Namen nicht geschrieben";
      return $Message; }
    if ( not (-f $fname) ) {
      $Message = "'$fname' ist keine regulĆ¤re  Daten, Namen nicht geschrieben";
      return $Message; }
    if ( not (-w $fname) ) {
      $Message = "'$fname' existiert, kann aber nicht Ć¼berschrieben werden, Namen nicht geschrieben";
      return $Message; }
    } # Filename exists
  return $Message;
  } # CheckOutFile

