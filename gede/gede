sub CheckOutFile
  { # Usage: $result = &CheckoutFile($filename);
    # Checks if the file with name as parameter is writeable.
    # Returns empty string if yes and Error-Message if not
  my($fname) = @_;
  my($Message) = "";

  if ( -e $fname ) {
    if ( -d $fname ) {
      $Message = "'$fname' ist ein Verzeichnisnamen, Namen nicht geschrieben";
      return $Message; }
    if ( not -f $fname ) {
      $Message = "'$fname' ist keine reguläre  Daten, Namen nicht geschrieben";
      return $Message; }
    if ( not -w $fname ) {
      $Message = "'$fname' existiert, kann aber nicht überschrieben werden, Namen nicht geschrieben";
      return $Message; }
    } # Filename exists
  return $Message;
  } # CheckOutFile

sub WriteNewUTF8File
  { # Usage:  $status = &WriteNewUTF8File($Filename,$z_text);
    #
    # Writes content of $z_text to file $filename and closes $filename
    # Returns success message if file was successfully written, else error message
  my($Filename,$z_text) = @_;
  my($l);
  my($Message) = "(Noch) keine Namen in '${Filename}' geschrieben";

  $l = scalar(@$z_text);

  if ( -e $Filename ) { rename($Filename,"$Filename.bak"); }
  if (not open(OUTUTF8,">:utf8",$Filename)) {
    return "$Filename konnte nicht geöffnet werden";
    }
  foreach $l (@$z_text) {
    if ( not print(OUTUTF8 "$l\n") ) {
      return "Schreibvorgang in $Filename ergab Fehler";
      }
    }
  if ( not close(OUTUTF8) ) {
    return "Fehler beim Schließen der Datei $Filename";
    }
  $Message = "$l Namen in die Datei '$Filename' geschrieben";
  return $Message;
  } # WriteNewUTF8File

sub WriteResultToFile()
  { # Usage:  $Result = &WriteResultToFile(\@Out,$Filename);
    # Prüft. ob die Datei $Filename schreibbar ist.
    # Falls ja, werden die String-Listenelemente von \Out als UTF-8
    # in die Date geschrieben
    # Der entstehende Status wird als $Result zurückgegeben.
  my($z_Out,$Filename) = @_;
  my($Result) = "Keine Namen in '${Filename}' geschrieben";

  $Result = &CheckOutFile($Filename); 
  if ( $Result ne "" ) { # Auf $Filename kann nicht geschrieben werden
    return $Result;
    }
  $Result = &WriteNewUTF8File($Filename,$z_Out);
  return $Result;
  } # WriteResultToFile

